# JIFLA Loan Review Tool - Environment Configuration
# IMPORTANT: Copy this file to .env and fill in the values.
# The .env file contains encryption keys and MUST NEVER be committed to version control.

# Anthropic API Key (required)
ANTHROPIC_API_KEY=sk-ant-...

# Database encryption key - generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DB_ENCRYPTION_KEY=generate_a_random_32_byte_hex_string

# File encryption key (separate from DB key)
FILE_ENCRYPTION_KEY=generate_a_different_random_32_byte_hex_string

# Session secret - generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=generate_a_random_64_byte_hex_string

# Server configuration
PORT=3000
NODE_ENV=development

# Database path
DATABASE_PATH=./data/jifla.db

# Upload directory
UPLOAD_DIR=./uploads

# Retention periods (days after application closed_at)
RETENTION_CREDIT_REPORTS=90
RETENTION_PII_DOCUMENTS=365
RETENTION_APPLICATION_RECORDS=1095

# Anthropic data usage policy last verified (update this date when you re-verify)
# IMPORTANT: Verify Anthropic's data usage policy at deployment:
# https://www.anthropic.com/privacy
ANTHROPIC_POLICY_VERIFIED_DATE=2025-01-01
